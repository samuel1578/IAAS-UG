                    "elements": [
                        "pending",
                        "approved",
                        "rejected"
                    ],
                    "size": 255,
                    "required": false,
                    "default": "pending"
                },
                {
                    "key": "createdAt",
                    "type": "datetime",
                    "required": true,
                    "default": null
